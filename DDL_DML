DROP TABLE IF EXISTS technician_expertise;
DROP TABLE IF EXISTS testing_event;
DROP TABLE IF EXISTS hangar_assignment;
DROP TABLE IF EXISTS technician;
DROP TABLE IF EXISTS traffic_controller;
DROP TABLE IF EXISTS employee_union;
DROP TABLE IF EXISTS airport_employee;
DROP TABLE IF EXISTS union_;
DROP TABLE IF EXISTS airplane;
DROP TABLE IF EXISTS hangar;
DROP TABLE IF EXISTS test;
DROP TABLE IF EXISTS plane_model;

CREATE TABLE union_ (
    union_id INTEGER PRIMARY KEY,
    union_name VARCHAR(100) NOT NULL UNIQUE,
    contact_info VARCHAR(200),
    established_date DATE,
    monthly_fee NUMERIC(8,2) DEFAULT 0
);

CREATE TABLE airport_employee (
    ssn VARCHAR(11) PRIMARY KEY,
    full_name VARCHAR(120) NOT NULL,
    address VARCHAR(250),
    phone VARCHAR(20),
    hire_date DATE NOT NULL DEFAULT CURRENT_DATE,
    birth_date DATE,
    gender CHAR(1),
    email VARCHAR(100) UNIQUE
);

CREATE TABLE employee_union (
    ssn VARCHAR(11) NOT NULL,
    union_id INTEGER NOT NULL,
    membership_number VARCHAR(50) NOT NULL UNIQUE,
    join_date DATE NOT NULL DEFAULT CURRENT_DATE,
    is_active BOOLEAN DEFAULT 1,
    PRIMARY KEY (ssn, union_id),
    FOREIGN KEY (ssn) REFERENCES airport_employee(ssn) ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (union_id) REFERENCES union_(union_id) ON UPDATE CASCADE ON DELETE RESTRICT
);

CREATE TABLE technician (
    ssn VARCHAR(11) PRIMARY KEY,
    specialization VARCHAR(100),
    years_of_experience INTEGER DEFAULT 0,
    certification_level VARCHAR(20),
    hourly_rate NUMERIC(10,2) DEFAULT 0,
    FOREIGN KEY (ssn) REFERENCES airport_employee(ssn) ON UPDATE CASCADE ON DELETE CASCADE
);

CREATE TABLE traffic_controller (
    ssn VARCHAR(11) PRIMARY KEY,
    last_medical_exam_date DATE NOT NULL,
    tower_assignment VARCHAR(50),
    certification_number VARCHAR(50) UNIQUE,
    shift_schedule VARCHAR(50),
    FOREIGN KEY (ssn) REFERENCES airport_employee(ssn) ON UPDATE CASCADE ON DELETE CASCADE
);

CREATE TABLE plane_model (
    model_no VARCHAR(30) PRIMARY KEY,
    manufacturer VARCHAR(60) NOT NULL,
    type VARCHAR(50) NOT NULL,
    typical_capacity INTEGER,
    max_range_km INTEGER,
    cruise_speed_kmh INTEGER
);

CREATE TABLE technician_expertise (
    technician_ssn VARCHAR(11) NOT NULL,
    model_no VARCHAR(30) NOT NULL,
    expertise_level VARCHAR(20) DEFAULT 'Certified',
    certification_date DATE NOT NULL DEFAULT CURRENT_DATE,
    PRIMARY KEY (technician_ssn, model_no),
    FOREIGN KEY (technician_ssn) REFERENCES technician(ssn) ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (model_no) REFERENCES plane_model(model_no) ON UPDATE CASCADE ON DELETE CASCADE
);

CREATE TABLE hangar (
    hangar_no VARCHAR(20) PRIMARY KEY,
    location VARCHAR(100) NOT NULL,
    capacity INTEGER NOT NULL,
    has_fire_suppression BOOLEAN DEFAULT 0,
    has_lighting BOOLEAN DEFAULT 1
);

CREATE TABLE airplane (
    plane_no VARCHAR(20) PRIMARY KEY,
    model_no VARCHAR(30) NOT NULL,
    current_hangar_no VARCHAR(20),
    status VARCHAR(20) DEFAULT 'Active',
    acquisition_date DATE NOT NULL,
    last_maintenance_date DATE,
    total_flight_hours INTEGER DEFAULT 0,
    FOREIGN KEY (model_no) REFERENCES plane_model(model_no) ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (current_hangar_no) REFERENCES hangar(hangar_no) ON UPDATE CASCADE ON DELETE SET NULL
);

CREATE TABLE hangar_assignment (
    assignment_id INTEGER PRIMARY KEY,
    plane_no VARCHAR(20) NOT NULL,
    hangar_no VARCHAR(20) NOT NULL,
    in_date DATE NOT NULL,
    in_time TIME NOT NULL,
    out_date DATE,
    out_time TIME,
    reason VARCHAR(100),
    FOREIGN KEY (plane_no) REFERENCES airplane(plane_no) ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (hangar_no) REFERENCES hangar(hangar_no) ON UPDATE CASCADE ON DELETE RESTRICT
);

CREATE TABLE test (
    test_id INTEGER PRIMARY KEY,
    test_name VARCHAR(100) NOT NULL UNIQUE,
    description TEXT,
    duration_hours NUMERIC(5,2) NOT NULL,
    frequency_days INTEGER,
    passing_score INTEGER DEFAULT 70
);

CREATE TABLE testing_event (
    event_id INTEGER PRIMARY KEY,
    plane_no VARCHAR(20) NOT NULL,
    technician_ssn VARCHAR(11) NOT NULL,
    test_id INTEGER NOT NULL,
    test_date DATE NOT NULL,
    test_time TIME NOT NULL,
    hours_spent NUMERIC(5,2) NOT NULL,
    score INTEGER NOT NULL,
    remarks TEXT,
    FOREIGN KEY (plane_no) REFERENCES airplane(plane_no) ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (technician_ssn) REFERENCES technician(ssn) ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (test_id) REFERENCES test(test_id) ON UPDATE CASCADE ON DELETE RESTRICT,
    UNIQUE(plane_no, test_id, test_date)
);

